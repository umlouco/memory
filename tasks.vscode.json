{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "memory:recall",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/memory/recall_turn_context.py",
        "--query",
        "${input:memoryQuery}",
        "--limit",
        "3"
      ],
      "problemMatcher": []
    },
    {
      "label": "memory:guarded-command",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "tools/memory/run_memory_guard.ps1",
        "-SessionId",
        "${input:memorySession}",
        "-UserRequest",
        "${input:memoryRequest}",
        "-Summary",
        "${input:memorySummary}",
        "-Outcome",
        "${input:memoryOutcome}",
        "-QueryMemory",
        "${input:memoryQuery}",
        "-RunCommand",
        "python -c \"print('replace this with your real agent wrapper')\""
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "memorySession",
      "type": "promptString",
      "description": "Session identifier",
      "default": "copilot-session"
    },
    {
      "id": "memoryRequest",
      "type": "promptString",
      "description": "User request summary"
    },
    {
      "id": "memorySummary",
      "type": "promptString",
      "description": "Work summary"
    },
    {
      "id": "memoryOutcome",
      "type": "promptString",
      "description": "Outcome"
    },
    {
      "id": "memoryQuery",
      "type": "promptString",
      "description": "Memory recall query"
    }
  ]
}
